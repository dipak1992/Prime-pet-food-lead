generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                      String           @id @default(uuid())
  name                    String
  address                 String?
  city                    String?
  state                   String?
  zip                     String?
  latitude                Decimal?
  longitude               Decimal?
  website                 String?
  email                   String?
  phone                   String?
  instagram               String?
  facebook                String?
  preferredChannel        PreferredChannel @default(email) @map("preferred_channel")
  googleRating            Decimal?         @map("google_rating")
  googleReviewCount       Int?             @map("google_review_count")
  sellsDogTreats          Boolean?         @map("sells_dog_treats")
  sellsCompetitorProducts Boolean          @default(false) @map("sells_competitor_products")
  competitorBrands        String[]         @map("competitor_brands")
  relevanceScore          Int?             @map("relevance_score")
  leadType                String?          @map("lead_type")
  intentLevel             String?          @map("intent_level")
  leadScore               Int?             @map("lead_score")
  leadTemperature         String?          @map("lead_temperature")
  source                  StoreSource      @default(manual)
  pipelineStage           PipelineStage    @default(new) @map("pipeline_stage")
  lostReason              String?          @map("lost_reason")
  notes                   String?
  contactedAt             DateTime?        @map("contacted_at")
  nextFollowUpAt          DateTime?        @map("next_follow_up_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  outreachEmails          OutreachEmail[]
  samples                 Sample[]
  wholesaleQuotes         WholesaleQuote[]
  activities              Activity[]
  deals                   Deal[]
  followUpSequences       FollowUpSequence[]

  @@map("stores")
}

model OutreachEmail {
  id           String          @id @default(uuid())
  storeId      String          @map("store_id")
  sequenceStep Int             @map("sequence_step")
  channel      OutreachChannel @default(email)
  subject      String?
  body         String
  sentAt       DateTime?       @map("sent_at")
  repliedAt    DateTime?       @map("replied_at")
  status       OutreachStatus  @default(draft)
  createdAt    DateTime        @default(now()) @map("created_at")
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("outreach_emails")
}

model Sample {
  id             String       @id @default(uuid())
  storeId        String       @map("store_id")
  shippedAt      DateTime?    @map("shipped_at")
  deliveredAt    DateTime?    @map("delivered_at")
  feedback       String?
  feedbackAt     DateTime?    @map("feedback_at")
  status         SampleStatus @default(requested)
  trackingNumber String?      @map("tracking_number")
  createdAt      DateTime     @default(now()) @map("created_at")
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("samples")
}

model EmailTemplate {
  id           String           @id @default(uuid())
  name         String
  category     TemplateCategory
  sequenceStep Int              @map("sequence_step")
  subject      String
  body         String
  isDefault    Boolean          @default(false) @map("is_default")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@map("email_templates")
}

model WholesaleQuote {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  tiers     Json
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("wholesale_quotes")
}

model ApiUsage {
  id           String   @id @default(uuid())
  apiName      String   @map("api_name")
  requestCount Int      @default(0) @map("request_count")
  date         DateTime @db.Date

  @@unique([apiName, date])
  @@map("api_usage")
}

// === Activity Timeline ===
model Activity {
  id        String       @id @default(uuid())
  storeId   String       @map("store_id")
  type      ActivityType
  title     String
  detail    String?
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("activities")
}

// === Deal / Revenue Tracking ===
model Deal {
  id               String     @id @default(uuid())
  storeId          String     @map("store_id")
  title            String
  value            Decimal    @default(0)
  status           DealStatus @default(open)
  expectedCloseAt  DateTime?  @map("expected_close_at")
  closedAt         DateTime?  @map("closed_at")
  lostReason       String?    @map("lost_reason")
  products         String[]
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  store            Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("deals")
}

// === Auto Follow-Up Sequences ===
model FollowUpSequence {
  id            String             @id @default(uuid())
  storeId       String             @map("store_id")
  status        SequenceStatus     @default(active)
  currentStep   Int                @default(1) @map("current_step")
  totalSteps    Int                @default(5) @map("total_steps")
  nextSendAt    DateTime?          @map("next_send_at")
  lastSentAt    DateTime?          @map("last_sent_at")
  completedAt   DateTime?          @map("completed_at")
  pausedAt      DateTime?          @map("paused_at")
  category      String             @default("local_pet_store")
  createdAt     DateTime           @default(now()) @map("created_at")
  store         Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("follow_up_sequences")
}

enum ActivityType {
  email_sent
  email_replied
  email_drafted
  stage_changed
  note_added
  sample_shipped
  sample_delivered
  sample_feedback
  deal_created
  deal_won
  deal_lost
  contact_updated
  store_imported
  website_scraped
  follow_up_scheduled
  follow_up_sent
}

enum DealStatus {
  open
  won
  lost
}

enum SequenceStatus {
  active
  paused
  completed
  cancelled
}

enum StoreSource {
  api_search
  manual
  csv_import
  bing_search
}

enum PipelineStage {
  new
  researched
  contacted
  sample_sent
  negotiating
  won
  lost
}

enum PreferredChannel {
  email
  phone
  instagram
  facebook
  in_person
}

enum OutreachChannel {
  email
  instagram
  phone
  in_person
}

enum OutreachStatus {
  draft
  sent
  replied
  no_response
}

enum SampleStatus {
  requested
  shipped
  delivered
  feedback_received
  order_placed
  declined
}

enum TemplateCategory {
  local_pet_store
  boutique
  premium_organic
  competitor_carrier
  online_store
  custom
}
